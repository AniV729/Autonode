# Autonode Backend — Environment Config
# Copy to .env and fill in your key (only needed for LLM-powered diagnosis)

# OpenAI (gpt-4o-mini is cheap + fast for hackathon)
OPENAI_API_KEY=sk-your-openai-key-here

# Alternative: Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Webhook URL for work order dispatch (optional)
# WEBHOOK_URL=https://your-webhook.com/orders

# Slack incoming webhook for real-time work order alerts
AUTONODE_SLACK_WEBHOOK_URL=

# SMTP settings for email work orders
AUTONODE_SMTP_HOST=
AUTONODE_SMTP_PORT=587
AUTONODE_SMTP_USERNAME=
AUTONODE_SMTP_PASSWORD=
AUTONODE_SMTP_USE_TLS=true
AUTONODE_ALERT_EMAIL_FROM=
AUTONODE_ALERT_EMAIL_TO=

# Bounded retention to cap memory/disk growth under heavy simulation
AUTONODE_MAX_EVENT_HISTORY=400
AUTONODE_MAX_WORK_ORDER_HISTORY=150
